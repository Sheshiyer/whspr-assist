---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}

const { currentSlug = '' } = Astro.props;

const allDocs = await getCollection('docs');

const sectionMeta: Record<string, { order: number; color: string }> = {
  Home:         { order: 0, color: 'var(--teal)' },
  Product:      { order: 1, color: 'var(--navy)' },
  Brand:        { order: 2, color: 'var(--gold)' },
  Audience:     { order: 3, color: 'var(--teal)' },
  Marketing:    { order: 4, color: '#E74C3C' },
  Partners:     { order: 5, color: 'var(--navy)' },
  deliverables: { order: 6, color: 'var(--charcoal)' },
};

const sections = new Map<string, typeof allDocs>();

for (const doc of allDocs) {
  const section = doc.data.section || 'Home';
  if (!sections.has(section)) {
    sections.set(section, []);
  }
  sections.get(section)!.push(doc);
}

const sortedSections = [...sections.entries()]
  .sort(([a], [b]) => (sectionMeta[a]?.order ?? 99) - (sectionMeta[b]?.order ?? 99))
  .map(([name, docs]) => ({
    name,
    color: sectionMeta[name]?.color || 'var(--text-muted)',
    items: docs.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  }));

function getDocHref(docId: string): string {
  if (docId === 'index') return '/docs/';
  return `/docs/${docId}`;
}

function isActive(docId: string, current: string): boolean {
  if (docId === 'index') {
    return current === '' || current === 'index' || current === undefined;
  }
  return docId === current;
}

function displayName(name: string): string {
  return name.charAt(0).toUpperCase() + name.slice(1);
}
---

<div class="sidebar-overlay" id="sidebarOverlay"></div>
<nav class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <a href="/" class="sidebar-home-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
      Home
    </a>
  </div>
  {sortedSections.map((section) => (
    <div class="sidebar-section">
      <button class="sidebar-section-header" type="button" aria-expanded="true">
        <span class="sidebar-dot" style={`background: ${section.color};`}></span>
        <span>{displayName(section.name)}</span>
        <svg class="sidebar-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <div class="sidebar-section-items">
        {section.items.map((doc) => (
          <a
            href={getDocHref(doc.id)}
            class:list={['sidebar-link', { active: isActive(doc.id, currentSlug) }]}
            aria-current={isActive(doc.id, currentSlug) ? 'page' : undefined}
          >
            {doc.data.title}
          </a>
        ))}
      </div>
    </div>
  ))}
</nav>

<script is:inline>
  document.querySelectorAll('.sidebar-section-header').forEach(function(header) {
    header.addEventListener('click', function() {
      var section = this.parentElement;
      var isCollapsed = section.classList.toggle('collapsed');
      this.setAttribute('aria-expanded', !isCollapsed);
    });
  });

  var menuBtn = document.getElementById('mobileMenuBtn');
  var sidebar = document.getElementById('sidebar');
  var overlay = document.getElementById('sidebarOverlay');

  function closeSidebar() {
    if (sidebar) sidebar.classList.remove('open');
    if (overlay) overlay.classList.remove('visible');
    document.body.style.overflow = '';
  }

  if (menuBtn) {
    menuBtn.addEventListener('click', function() {
      var isOpen = sidebar && sidebar.classList.contains('open');
      if (isOpen) {
        closeSidebar();
      } else {
        if (sidebar) sidebar.classList.add('open');
        if (overlay) overlay.classList.add('visible');
        document.body.style.overflow = 'hidden';
      }
    });
  }

  if (overlay) {
    overlay.addEventListener('click', closeSidebar);
  }

  // Close sidebar when a link is tapped (mobile)
  document.querySelectorAll('.sidebar-link, .sidebar-home-link').forEach(function(link) {
    link.addEventListener('click', function() {
      if (window.innerWidth <= 768) {
        closeSidebar();
      }
    });
  });
</script>
