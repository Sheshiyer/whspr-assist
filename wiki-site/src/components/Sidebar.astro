---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}

const { currentSlug = '' } = Astro.props;

const allDocs = await getCollection('docs');

// Define section order and metadata
const sectionMeta: Record<string, { icon: string; order: number }> = {
  Home:      { icon: '\u{1F3E0}', order: 0 },
  Product:   { icon: '\u{1F4E6}', order: 1 },
  Brand:     { icon: '\u{1F3A8}', order: 2 },
  Audience:  { icon: '\u{1F465}', order: 3 },
  Marketing: { icon: '\u{1F4E3}', order: 4 },
  Partners:  { icon: '\u{1F91D}', order: 5 },
};

// Group docs by section and sort
const sections = new Map<string, typeof allDocs>();

for (const doc of allDocs) {
  const section = doc.data.section || 'Home';
  if (!sections.has(section)) {
    sections.set(section, []);
  }
  sections.get(section)!.push(doc);
}

// Sort sections by their defined order, then sort items within each section
const sortedSections = [...sections.entries()]
  .sort(([a], [b]) => (sectionMeta[a]?.order ?? 99) - (sectionMeta[b]?.order ?? 99))
  .map(([name, docs]) => ({
    name,
    icon: sectionMeta[name]?.icon || '\u{1F4C4}',
    items: docs.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  }));

function getDocHref(docId: string): string {
  if (docId === 'index') {
    return `${import.meta.env.BASE_URL}/docs/`;
  }
  return `${import.meta.env.BASE_URL}/docs/${docId}`;
}

function isActive(docId: string, current: string): boolean {
  if (docId === 'index') {
    return current === '' || current === 'index' || current === undefined;
  }
  return docId === current;
}
---

<div class="sidebar-overlay" id="sidebarOverlay"></div>
<nav class="sidebar" id="sidebar">
  {sortedSections.map((section) => (
    <div class="sidebar-section">
      <div class="sidebar-section-header">
        <span class="sidebar-section-icon">{section.icon}</span>
        <span>{section.name}</span>
        <span class="sidebar-section-chevron">&#x25BC;</span>
      </div>
      <div class="sidebar-section-items">
        {section.items.map((doc) => (
          <a
            href={getDocHref(doc.id)}
            class:list={['sidebar-link', { active: isActive(doc.id, currentSlug) }]}
          >
            {doc.data.title}
          </a>
        ))}
      </div>
    </div>
  ))}
</nav>

<script is:inline>
  // Collapsible sections
  document.querySelectorAll('.sidebar-section-header').forEach(function(header) {
    header.addEventListener('click', function() {
      var section = this.parentElement;
      section.classList.toggle('collapsed');
    });
  });

  // Mobile sidebar toggle
  var menuBtn = document.getElementById('mobileMenuBtn');
  var sidebar = document.getElementById('sidebar');
  var overlay = document.getElementById('sidebarOverlay');

  function closeSidebar() {
    if (sidebar) sidebar.classList.remove('open');
    if (overlay) overlay.classList.remove('visible');
  }

  if (menuBtn) {
    menuBtn.addEventListener('click', function() {
      var isOpen = sidebar && sidebar.classList.contains('open');
      if (isOpen) {
        closeSidebar();
      } else {
        if (sidebar) sidebar.classList.add('open');
        if (overlay) overlay.classList.add('visible');
      }
    });
  }

  if (overlay) {
    overlay.addEventListener('click', closeSidebar);
  }
</script>
